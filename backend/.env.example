# backend/.env のテンプレート。実値を入れた backend/.env はコミットしない。
# Supabase（backend 内部処理用。クライアントには絶対出さない / CLAUDE.md §4, §12）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=    # RLS貫通の全権鍵。内部処理のみ
SUPABASE_JWT_SECRET=          # JWT検証用（Supabase: Project Settings > API > JWT Secret / HS256）
DATABASE_URL=

# CORS 許可オリジン（JSON配列）。未設定ならコード側デフォルト ["http://localhost:3000"]。
# CORS_ORIGINS=["http://localhost:3000"]
